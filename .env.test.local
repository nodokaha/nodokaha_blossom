# Test environment specific configuration
# This file is loaded in test environment and overrides .env.test

# Database configuration for tests (use SQLite in memory for faster tests)
DATABASE_URL="sqlite:///./var/test.db"

# Logging level for tests
LOG_LEVEL=warning

# Disable cache in tests for consistency
APP_CACHE_DIR=./var/cache/test

# Test specific secret (different from production)
APP_SECRET=test_secret_key_for_testing

# Default URI for routing in tests
DEFAULT_URI=http://localhost

# Messenger configuration for tests (use sync transport)
MESSENGER_TRANSPORT_DSN=sync://