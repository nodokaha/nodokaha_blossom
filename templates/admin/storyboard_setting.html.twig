{% extends 'base.html.twig' %}

{% block title %}運営: ストーリーボード設定{% endblock %}

{% block body %}
    <style>
        .ops-wrap{max-width:980px;margin:2rem auto;padding:1.2rem;background:#0f172a;color:#e2e8f0;border-radius:16px}
        .panel{background:#111827;border:1px solid #334155;border-radius:12px;padding:1rem;margin-bottom:1rem}
        .grid{display:grid;gap:.8rem;grid-template-columns:repeat(auto-fit,minmax(220px,1fr))}
        input,textarea{width:100%;padding:.6rem;border-radius:8px;border:1px solid #475569;background:#020617;color:#e2e8f0}
        button{padding:.7rem 1.1rem;border:0;border-radius:8px;background:#2563eb;color:#fff;font-weight:700;cursor:pointer}
        .hint{font-size:.85rem;color:#94a3b8}
        .challenge{border-left:3px solid #22d3ee;padding:.4rem .8rem;margin:.6rem 0;background:#0b1228}
    </style>
    <main class="ops-wrap">
        <h1>運営管理画面（非公開導線）</h1>
        <p class="hint">この画面への導線は一般画面に表示していません。URLを知る運営ユーザーのみ利用してください。</p>

        {% for message in app.flashes('success') %}
            <div class="panel">{{ message }}</div>
        {% endfor %}

        <section class="panel">
            <h2>今期課題風ストーリーボード設定</h2>
            <form method="post">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_storyboard_setting') }}">
                <div class="grid">
                    <label>期（例: 2026-H2）<input type="text" name="period" value=""></label>
                    <label>チャプター名<input type="text" name="title" value="{{ world.chapter|default('') }}"></label>
                </div>
                <label>課題・達成目標
                    <textarea name="objective" rows="4">{{ world.objective|default('') }}</textarea>
                </label>
                <p class="hint">保存時に最新チャプターへ反映し、履歴は直近12件まで保持します。</p>
                <button type="submit">ストーリーボードを保存</button>
            </form>
        </section>

        <section class="panel">
            <h2>設定済みストーリーボード履歴</h2>
            {% if semiannualChallenges is empty %}
                <p>履歴はまだありません。</p>
            {% else %}
                {% for item in semiannualChallenges|reverse %}
                    <article class="challenge">
                        <strong>{{ item.period|default('未設定') }}</strong>
                        <div>{{ item.title|default('無題チャプター') }}</div>
                        <p>{{ item.objective|default('目的未設定') }}</p>
                    </article>
                {% endfor %}
            {% endif %}
        </section>
    </main>
{% endblock %}
