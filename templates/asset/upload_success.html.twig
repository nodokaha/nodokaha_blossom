{% extends 'basisvr_base.html.twig' %}

{% block title %}Upload Success{% endblock %}

{% block body %}
    <div class="upload-success-container">
        <div class="success-card">
            <div class="success-header">
                <div class="success-icon">✓</div>
                <h1>アップロード完了</h1>
            </div>

            <div class="asset-details">
                <div class="detail-section">
                    <h3>ファイル情報</h3>
                    <div class="info-row">
                        <label>ファイル名:</label>
                        <span>{{ asset.originalName }}</span>
                    </div>
                    <div class="info-row">
                        <label>ファイルサイズ:</label>
                        <span>{{ (asset.size / 1024 / 1024)|round(2) }} MB</span>
                    </div>
                    <div class="info-row">
                        <label>種別:</label>
                        <span>{{ asset.assetTypeLabel }}</span>
                    </div>
                    <div class="info-row">
                        <label>MIME Type:</label>
                        <span>{{ asset.mimeType }}</span>
                    </div>
                    <div class="info-row">
                        <label>アップロード日時:</label>
                        <span>{{ asset.createdAt|format_datetime('medium', 'short', locale='ja') }}</span>
                    </div>
                </div>

                <div class="detail-section">
                    <h3>ダウンロードURL</h3>
                    <div class="copy-row">
                        <input type="text" class="url-input" id="downloadUrl" value="{{ downloadUrl }}" readonly>
                        <button type="button" class="btn-copy" onclick="copyToClipboard('downloadUrl')">
                            コピー
                        </button>
                    </div>
                    <small>このURLでアセットをダウンロードできます</small>
                </div>

                <div class="detail-section">
                    <h3>暗号化解除キー</h3>
                    <div class="copy-row">
                        <input type="text" class="key-input" id="encryptionKey" value="{{ asset.encryptionKey }}" readonly>
                        <button type="button" class="btn-copy" onclick="copyToClipboard('encryptionKey')">
                            コピー
                        </button>
                    </div>
                    <small>このキーを使用して、アセットを暗号化解除できます</small>
                </div>
            </div>

            <div class="action-buttons">
                <a href="{{ path('basisvr_asset_upload') }}" class="btn btn-primary">別のファイルをアップロード</a>
                <a href="{{ path('basisvr_asset_index') }}" class="btn btn-secondary">アセット一覧に戻る</a>
            </div>
        </div>
    </div>

    <style>
        .upload-success-container {
            max-width: 700px;
            margin: 40px auto;
            padding: 20px;
        }

        .success-card {
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            padding: 40px;
        }

        .success-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .success-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 60px;
            height: 60px;
            background-color: #28a745;
            color: white;
            border-radius: 50%;
            font-size: 32px;
            margin-bottom: 15px;
        }

        .success-header h1 {
            color: #28a745;
            margin: 0;
            font-size: 28px;
        }

        .asset-details {
            margin-bottom: 30px;
        }

        .detail-section {
            background: #f8f9fa;
            padding: 20px;
            margin-bottom: 15px;
            border-radius: 6px;
            border-left: 4px solid #007bff;
        }

        .detail-section h3 {
            margin: 0 0 15px 0;
            color: #333;
            font-size: 16px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #dee2e6;
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-row label {
            font-weight: 600;
            color: #555;
            min-width: 120px;
        }

        .info-row span {
            color: #333;
            word-break: break-all;
        }

        .copy-row {
            display: flex;
            gap: 10px;
            margin-bottom: 8px;
        }

        .url-input,
        .key-input {
            flex: 1;
            padding: 10px 12px;
            border: 1px solid #dee2e6;
            border-radius: 4px;
            font-family: 'Courier New', monospace;
            font-size: 12px;
            background-color: white;
            cursor: text;
        }

        .btn-copy {
            padding: 10px 20px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: background-color 0.3s ease;
            white-space: nowrap;
        }

        .btn-copy:hover {
            background-color: #0056b3;
        }

        .btn-copy.copied {
            background-color: #28a745;
        }

        .detail-section small {
            display: block;
            color: #6c757d;
            font-size: 12px;
            margin-top: 5px;
        }

        .action-buttons {
            display: flex;
            gap: 10px;
            margin-top: 30px;
            justify-content: center;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            transition: all 0.3s ease;
            font-weight: 600;
        }

        .btn-primary {
            background-color: #007bff;
            color: white;
        }

        .btn-primary:hover {
            background-color: #0056b3;
        }

        .btn-secondary {
            background-color: #6c757d;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #545b62;
        }

        @media (max-width: 600px) {
            .success-card {
                padding: 20px;
            }

            .copy-row {
                flex-direction: column;
            }

            .btn-copy {
                width: 100%;
            }

            .action-buttons {
                flex-direction: column;
            }

            .btn {
                width: 100%;
            }

            .info-row {
                flex-direction: column;
                gap: 5px;
            }
        }
    </style>

    <script>
        function copyToClipboard(elementId) {
            const element = document.getElementById(elementId);
            const button = event.target;
            
            // Select and copy
            element.select();
            document.execCommand('copy');
            
            // Show feedback
            const originalText = button.textContent;
            button.textContent = 'コピーしました！';
            button.classList.add('copied');
            
            setTimeout(() => {
                button.textContent = originalText;
                button.classList.remove('copied');
            }, 2000);
        }
    </script>
{% endblock %}
