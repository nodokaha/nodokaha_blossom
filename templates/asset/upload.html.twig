{% extends 'basisvr_base.html.twig' %}

{% block title %}Upload Asset{% endblock %}

{% block body %}
    <div class="asset-upload-container">
        <h1>アセットをアップロード</h1>
        <p class="subtitle">VR用のモデル、画像、その他のアセットをアップロードしてください</p>

        <div class="upload-form-wrapper">
            {{ form_start(form, {'attr': {'class': 'asset-upload-form', 'novalidate': 'novalidate'}}) }}
                <div class="form-group">
                    {{ form_label(form.asset, 'ファイルを選択', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.asset, {'attr': {'class': 'form-control file-input', 'accept': '.BEE'}}) }}
                    <small class="form-text">対応ファイル: BEE (最大100M)</small>
                    {{ form_errors(form.asset) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.encryptionKey, '暗号化キー', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.encryptionKey, {'attr': {'class': 'form-control encryption-key-input'}}) }}
                    <small class="form-text">このキーは他のサービスで利用できます</small>
                    {{ form_errors(form.encryptionKey) }}
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">アップロード</button>
                    <a href="{{ path('basisvr_asset_index') }}" class="btn btn-secondary">キャンセル</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>

    <style>
        .asset-upload-container {
            max-width: 600px;
            margin: 40px auto;
            padding: 20px;
        }

        .asset-upload-container h1 {
            color: #333;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #666;
            margin-bottom: 30px;
            font-size: 14px;
        }

        .upload-form-wrapper {
            background: #f8f9fa;
            padding: 30px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
        }

        .file-input,
        .encryption-key-input {
            display: block;
            width: 100%;
            padding: 10px;
            border: 2px solid #dee2e6;
            border-radius: 4px;
            font-size: 14px;
            box-sizing: border-box;
        }

        .file-input {
            cursor: pointer;
        }

        .file-input:hover {
            border-color: #007bff;
        }

        .encryption-key-input {
            font-family: 'Courier New', monospace;
        }

        .encryption-key-input:focus {
            outline: none;
            border-color: #007bff;
            box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
        }

        .form-text {
            display: block;
            margin-top: 8px;
            color: #6c757d;
            font-size: 12px;
        }

        .form-error {
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
            padding: 12px;
            border-radius: 4px;
            margin-top: 8px;
        }

        .form-error p {
            margin: 0;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background-color: #007bff;
            color: white;
        }

        .btn-primary:hover {
            background-color: #0056b3;
        }

        .btn-secondary {
            background-color: #6c757d;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #545b62;
        }
    </style>
{% endblock %}
