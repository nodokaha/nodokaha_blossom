{% extends 'base.html.twig' %}

{% block title %}プロジェクト見直しブログ{% endblock %}

{% block body %}
<main class="portfolio-shell">
    <section class="portfolio-hero">
        <div>
            <p class="eyebrow">PROJECT REVIEW BLOG</p>
            <h1>プロジェクト見直しブログ</h1>
            <p class="lead">このサイトは、実装済みの機能・運用メモ・改善判断を記事として読み直すためのレビュー拠点です。記事一覧、投稿、検証用デモへ迷わず移動できる構成に整理しました。</p>
            <div class="hero-actions">
                <a class="button-link" href="{{ path('basisvr_event_index') }}">レビュー記事を読む</a>
                <a class="button-link secondary" href="{{ path('basisvr_event_new') }}">見直し記事を書く</a>
            </div>
        </div>
        <aside class="hero-card" aria-label="review blog status">
            <span class="status-dot"></span>
            <strong>Review first</strong>
            <p>個人紹介や不要な入口を外し、読者がプロジェクトの判断材料へ直行できるブログ型の入口に変更しました。</p>
        </aside>
    </section>

    <section class="route-grid" aria-label="レビュー機能">
        {% for link in links %}
            <article class="route-card">
                <span class="route-number">{{ '%02d'|format(loop.index) }}</span>
                <h2>{{ link.label }}</h2>
                <p>{{ link.description }}</p>
                <a href="{{ path(link.route) }}">開く</a>
            </article>
        {% endfor %}
    </section>
</main>
{% endblock %}
