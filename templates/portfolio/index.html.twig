{% extends 'base.html.twig' %}

{% block title %}BasisVR コンテンツ投稿{% endblock %}

{% block body %}
<main class="portfolio-shell">
    <section class="portfolio-hero">
        <div>
            <p class="eyebrow">BASISVR CONTENTS</p>
            <h1>BasisVR コンテンツ投稿</h1>
            <p class="lead">このサイトは、BasisVR向けのProp・World・Avatarを説明、関連アセット、タグ付きで共有するための入口です。コンテンツ一覧、投稿、検証用デモへ迷わず移動できます。</p>
            <div class="hero-actions">
                <a class="button-link" href="{{ path('basisvr_event_index') }}">コンテンツを読む</a>
                <a class="button-link secondary" href="{{ path('basisvr_event_new') }}">コンテンツを投稿</a>
            </div>
        </div>
        <aside class="hero-card" aria-label="BasisVR content status">
            <span class="status-dot"></span>
            <strong>Content first</strong>
            <p>タイトル、種別、説明、関連アセット、タグを中心に、利用者がBasisVR内で試したい投稿へ直行できる構成にしました。</p>
        </aside>
    </section>

    <section class="route-grid" aria-label="BasisVRコンテンツ機能">
        {% for link in links %}
            <article class="route-card">
                <span class="route-number">{{ '%02d'|format(loop.index) }}</span>
                <h2>{{ link.label }}</h2>
                <p>{{ link.description }}</p>
                <a href="{{ path(link.route) }}">開く</a>
            </article>
        {% endfor %}
    </section>
</main>
{% endblock %}
