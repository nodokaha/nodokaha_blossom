{% extends 'base.html.twig' %}

{% block title %}各ページ動線{% endblock %}

{% block body %}
<main class="portfolio-shell">
    <section class="portfolio-panel">
        <p class="eyebrow">SITE MAP</p>
        <h1>各ページ動線</h1>
        <p class="lead">ポートフォリオの玄関から、既存機能と新規実験に直接移動できるよう導線を整理しました。</p>
    </section>
    <section class="route-grid">
        {% for link in links %}
            <article class="route-card">
                <h2>{{ link.label }}</h2>
                <p>{{ link.description }}</p>
                <a href="{{ path(link.route) }}">{{ link.label }}へ進む</a>
            </article>
        {% endfor %}
    </section>
</main>
{% endblock %}
