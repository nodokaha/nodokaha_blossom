{% extends 'basisvr_base.html.twig' %}

{% block title %}New Event Post{% endblock %}

{% block body %}
<main class="blog-page blog-form-page">
  <section class="blog-hero compact-hero">
    <div>
      <p class="eyebrow">New Post</p>
      <h1>Create Event Post</h1>
      <p class="hero-copy">Share your event with the community using a short title and a strong description.</p>
    </div>
  </section>

  <section class="form-panel card">
    {{ form_start(form, {'attr': {'class': 'blog-form'}}) }}
      {{ form_row(form.title) }}
      {{ form_row(form.authorName) }}
      {{ form_row(form.content) }}
      <div class="form-actions"><button class="blog-button" type="submit">Submit</button></div>
    {{ form_end(form) }}
  </section>
</main>
{% endblock %}