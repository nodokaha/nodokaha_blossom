{% extends 'basisvr_base.html.twig' %}

{% block title %}レビュー記事作成{% endblock %}

{% block body %}
<main id="basisvr-main" class="blog-page blog-form-page">
  <nav class="breadcrumb" aria-label="パンくずリスト">
    <a href="{{ path('basisvr_event_index') }}">レビュー一覧</a>
    <span aria-hidden="true">/</span>
    <span>新規レビュー</span>
  </nav>

  <section class="blog-hero compact-hero">
    <div>
      <p class="eyebrow">New Review</p>
      <h1>見直し記事を作成</h1>
      <p class="hero-copy">タイトル、レビュアー名、本文の3項目で公開できます。変更理由、良かった点、懸念、次のアクションが分かる内容にしましょう。</p>
    </div>
  </section>

  <section class="form-panel card" aria-labelledby="new-post-heading">
    <div class="form-intro">
      <h2 id="new-post-heading">レビュー内容</h2>
      <p>CSRF保護に加え、ボットが埋めやすい非表示項目を検知して自動投稿を抑止します。</p>
    </div>
    {{ form_start(form, {'attr': {'class': 'blog-form'}}) }}
      {{ form_errors(form) }}
      {{ form_row(form.title) }}
      {{ form_row(form.authorName) }}
      {{ form_row(form.content) }}
      {{ form_row(form.website) }}
      {{ form_row(form.submissionToken) }}
      <div class="form-actions">
        <button class="blog-button" type="submit">レビューを公開</button>
        <a class="ghost-button" href="{{ path('basisvr_event_index') }}">キャンセル</a>
      </div>
    {{ form_end(form) }}
  </section>
</main>
{% endblock %}
