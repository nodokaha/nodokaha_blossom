{% extends 'basisvr_base.html.twig' %}

{% block title %}BasisVR コンテンツ投稿{% endblock %}

{% block body %}
<main id="basisvr-main" class="blog-page blog-form-page">
  <nav class="breadcrumb" aria-label="パンくずリスト">
    <a href="{{ path('basisvr_event_index') }}">コンテンツ一覧</a>
    <span aria-hidden="true">/</span>
    <span>新規コンテンツ</span>
  </nav>

  <section class="blog-hero compact-hero">
    <div>
      <p class="eyebrow">New BasisVR Content</p>
      <h1>BasisVRコンテンツを投稿</h1>
      <p class="hero-copy">タイトル、説明、コンテンツ種別、投稿者名に加えて、関連アセットとタグを登録できます。利用シーンや導入手順が伝わる内容にしましょう。</p>
    </div>
  </section>

  <section class="form-panel card" aria-labelledby="new-post-heading">
    <div class="form-intro">
      <h2 id="new-post-heading">コンテンツ情報</h2>
      <p>CSRF保護に加え、ボットが埋めやすい非表示項目を検知して自動投稿を抑止します。</p>
    </div>
    {{ form_start(form, {'attr': {'class': 'blog-form'}}) }}
      {{ form_errors(form) }}
      {{ form_row(form.title) }}
      {{ form_row(form.contentType) }}
      {{ form_row(form.authorName) }}
      {{ form_row(form.description) }}
      {{ form_row(form.relatedAssets) }}
      {{ form_row(form.tags) }}
      {{ form_row(form.website) }}
      {{ form_row(form.submissionToken) }}
      <div class="form-actions">
        <button class="blog-button" type="submit">コンテンツを公開</button>
        <a class="ghost-button" href="{{ path('basisvr_event_index') }}">キャンセル</a>
      </div>
    {{ form_end(form) }}
  </section>
</main>
{% endblock %}
