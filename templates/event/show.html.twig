{% extends 'basisvr_base.html.twig' %}

{% block title %}{{ post.title }} — Event{% endblock %}

{% block body %}
<main class="container" style="max-width:800px;margin:1.5rem auto;padding:1rem;">
  <article class="card" style="padding:1rem;">
    <h2>{{ post.title }}</h2>
    <small class="text-muted">By {{ post.authorName }} · {{ post.publishedAt|date('Y-m-d H:i') }}</small>
    <div style="margin-top:1rem;white-space:pre-wrap;">{{ post.content }}</div>
  </article>

  <section style="margin-top:1rem;">
    <h3>Comments ({{ post.comments|length }})</h3>
    <div class="comment-list" style="display:grid;gap:0.75rem;margin-top:0.5rem;">
      {% for c in post.comments %}
        <div class="comment card" style="padding:0.75rem;">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <strong>{{ c.authorName }}</strong>
            <small class="text-muted">{{ c.publishedAt|date('Y-m-d H:i') }}</small>
          </div>
          <div style="margin-top:0.5rem;white-space:pre-wrap;">{{ c.content }}</div>
        </div>
      {% else %}
        <p class="text-muted">No comments yet — be the first to reply.</p>
      {% endfor %}
    </div>
  </section>

  <section style="margin-top:1rem;">
    <h3>Leave a comment</h3>
    <div class="card" style="padding:1rem;margin-top:0.5rem;">
      {{ form_start(commentForm) }}
        {{ form_widget(commentForm) }}
        <div style="margin-top:0.5rem;"><button type="submit">Post Comment</button></div>
      {{ form_end(commentForm) }}
    </div>
  </section>
</main>
{% endblock %}
