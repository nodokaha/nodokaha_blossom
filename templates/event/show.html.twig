{% extends 'basisvr_base.html.twig' %}

{% block title %}{{ post.title }} — Event{% endblock %}

{% block body %}
<main class="blog-page blog-article-page">
  <section class="article-hero">
    <div>
      <p class="eyebrow">Event Post</p>
      <h1>{{ post.title }}</h1>
      <p class="article-meta">By {{ post.authorName }} · {{ post.publishedAt|date('Y.m.d H:i') }}</p>
    </div>
  </section>

  <article class="post-content card">
    <div class="content-body">{{ post.content|nl2br }}</div>
  </article>

  <section class="comments-section">
    <div class="section-header">
      <h2>Comments</h2>
      <span class="comment-count">({{ post.comments|length }})</span>
    </div>
    <div class="comment-thread">
      {% for c in post.comments %}
        <div class="comment-card">
          <div class="comment-head">
            <strong>{{ c.authorName }}</strong>
            <span>{{ c.publishedAt|date('Y.m.d H:i') }}</span>
          </div>
          <div class="comment-body">{{ c.content|nl2br }}</div>
        </div>
      {% else %}
        <div class="empty-state card">
          <p>No comments yet. Be the first to reply.</p>
        </div>
      {% endfor %}
    </div>
  </section>

  <section class="comment-form">
    <h2>Leave a comment</h2>
    <div class="card form-card">
      {{ form_start(commentForm) }}
        {{ form_widget(commentForm) }}
        <div class="form-actions"><button class="blog-button" type="submit">Post Comment</button></div>
      {{ form_end(commentForm) }}
    </div>
  </section>
</main>
{% endblock %}
