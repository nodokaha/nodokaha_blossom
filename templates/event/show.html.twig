{% extends 'basisvr_base.html.twig' %}

{% block title %}{{ post.title }} — BasisVR イベントブログ{% endblock %}

{% block body %}
<main id="basisvr-main" class="blog-page blog-article-page">
  <nav class="breadcrumb" aria-label="パンくずリスト">
    <a href="{{ path('basisvr_event_index') }}">イベントブログ</a>
    <span aria-hidden="true">/</span>
    <span>{{ post.title }}</span>
  </nav>

  <section class="article-hero">
    <div>
      <p class="eyebrow">Event Post</p>
      <h1>{{ post.title }}</h1>
      <p class="article-meta">{{ post.authorName }} · <time datetime="{{ post.publishedAt|date('c') }}">{{ post.publishedAt|date('Y.m.d H:i') }}</time></p>
    </div>
    <div class="article-actions" aria-label="記事アクション">
      <a class="ghost-button" href="{{ path('basisvr_event_index') }}">一覧へ戻る</a>
      <a class="blog-button" href="#comment-form">コメントする</a>
    </div>
  </section>

  <article class="post-content card">
    <div class="content-body">{{ post.content|nl2br }}</div>
  </article>

  <section id="comments" class="comments-section" aria-labelledby="comments-heading">
    <div class="section-header">
      <h2 id="comments-heading">コメント</h2>
      <span class="comment-count">{{ post.comments|length }}件</span>
    </div>
    <div class="comment-thread">
      {% for c in post.comments %}
        <article class="comment-card">
          <div class="comment-head">
            <strong>{{ c.authorName }}</strong>
            <time datetime="{{ c.publishedAt|date('c') }}">{{ c.publishedAt|date('Y.m.d H:i') }}</time>
          </div>
          <div class="comment-body">{{ c.content|nl2br }}</div>
        </article>
      {% else %}
        <div class="empty-state card">
          <h3>まだコメントはありません</h3>
          <p>参加表明や質問を投稿すると、次の人が状況を把握しやすくなります。</p>
        </div>
      {% endfor %}
    </div>
  </section>

  <section id="comment-form" class="comment-form" aria-labelledby="comment-form-heading">
    <div class="section-header">
      <h2 id="comment-form-heading">コメントを書く</h2>
      <p>スパム防止のため、空欄のままにする検証欄を自動確認しています。</p>
    </div>
    <div class="card form-card">
      {{ form_start(commentForm, {'attr': {'class': 'blog-form'}}) }}
        {{ form_errors(commentForm) }}
        {{ form_row(commentForm.authorName) }}
        {{ form_row(commentForm.content) }}
        {{ form_row(commentForm.website) }}
        {{ form_row(commentForm.submissionToken) }}
        <div class="form-actions">
          <button class="blog-button" type="submit">コメントを投稿</button>
          <a class="ghost-button" href="{{ path('basisvr_event_index') }}">一覧へ戻る</a>
        </div>
      {{ form_end(commentForm) }}
    </div>
  </section>
</main>
{% endblock %}
