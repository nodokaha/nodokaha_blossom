{% extends 'basisvr_base.html.twig' %}

{% block title %}BasisVR コンテンツ投稿{% endblock %}

{% block body %}
<main id="basisvr-main" class="blog-page">
  <section class="blog-hero">
    <div>
      <p class="eyebrow">BasisVR Contents</p>
      <h1>BasisVR コンテンツ投稿</h1>
      <p class="hero-copy">Prop、World、AvatarなどのBasisVR向けコンテンツを、説明・関連アセット・タグと一緒に共有します。使い方や同梱物を一覧から確認できます。</p>
      <div class="hero-actions" aria-label="主要アクション">
        <a class="blog-button" href="{{ path('basisvr_event_new') }}">コンテンツを投稿する</a>
        <a class="ghost-button" href="#post-list">投稿一覧を見る</a>
      </div>
    </div>
    <aside class="hero-checklist" aria-label="コンテンツ投稿時の確認事項">
      <h2>投稿に含める情報</h2>
      <ul>
        <li>Prop / World / Avatar の種別</li>
        <li>利用シーンと導入手順</li>
        <li>関連アセットと検索用タグ</li>
      </ul>
    </aside>
  </section>

  <section class="blog-toolbar" aria-label="コンテンツ投稿概要">
    <div>
      <strong>{{ posts|length }}</strong>
      <span>件の公開コンテンツ</span>
    </div>
    <p>新着順で表示しています。種別、タグ、コメント数からBasisVR内で使いたい投稿を探せます。</p>
  </section>

  <section id="post-list" class="post-list" aria-label="BasisVRコンテンツ一覧">
    {% for post in posts %}
      {% set plainDescription = post.description|striptags %}
      {% set excerpt = plainDescription|slice(0, 180) ~ (plainDescription|length > 180 ? '…' : '') %}
      <article class="post-list-item">
        <div class="post-list-gutter" aria-hidden="true">{{ '%02d'|format(loop.index) }}</div>
        <div class="post-list-body">
          <div class="post-card-header">
            <span class="post-category">{{ post.contentTypeLabel }}</span>
            <time class="post-meta" datetime="{{ post.publishedAt|date('c') }}">{{ post.publishedAt|date('Y.m.d H:i') }}</time>
          </div>
          <h2 class="post-title">
            {% if post.id is defined and post.id %}
              <a href="{{ path('basisvr_event_show', {id: post.id}) }}">{{ post.title }}</a>
            {% else %}
              {{ post.title }}
            {% endif %}
          </h2>
          <p class="post-excerpt">{{ excerpt }}</p>
          {% if post.tags is not empty %}
            <div class="post-tags" aria-label="タグ">
              {% for tag in post.tags %}<span>#{{ tag }}</span>{% endfor %}
            </div>
          {% endif %}
          <div class="post-footer">
            <span class="post-author">@{{ post.authorName }}</span>
            <span class="post-comment-count">{{ post.comments|length }} comments</span>
            {% if post.id is defined and post.id %}
              <a class="more-link" href="{{ path('basisvr_event_show', {id: post.id}) }}">詳細とコメントへ →</a>
            {% endif %}
          </div>
        </div>
      </article>
    {% else %}
      <div class="empty-state card">
        <h2>まだコンテンツ投稿はありません</h2>
        <p>最初のBasisVRコンテンツを投稿して、使い方や関連アセットを共有しましょう。</p>
        <a class="blog-button" href="{{ path('basisvr_event_new') }}">最初のコンテンツを投稿</a>
      </div>
    {% endfor %}
  </section>
</main>
{% endblock %}
