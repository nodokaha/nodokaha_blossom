{% extends 'basisvr_base.html.twig' %}

{% block title %}BasisVR イベントブログ{% endblock %}

{% block body %}
<main id="basisvr-main" class="blog-page">
  <section class="blog-hero">
    <div>
      <p class="eyebrow">Community Journal</p>
      <h1>BasisVR イベントブログ</h1>
      <p class="hero-copy">最新のお知らせ、イベント告知、参加者コメントを一か所で確認できます。エディターのワークスペースのように、必要な情報を一覧から素早く読み取り、詳細へ移動できます。</p>
      <div class="hero-actions" aria-label="主要アクション">
        <a class="blog-button" href="{{ path('basisvr_event_new') }}">新規投稿する</a>
        <a class="ghost-button" href="#post-list">投稿一覧を見る</a>
      </div>
    </div>
    <aside class="hero-checklist" aria-label="投稿時の確認事項">
      <h2>投稿前チェック</h2>
      <ul>
        <li>日時・場所・参加方法を明記</li>
        <li>質問は各記事のコメントへ集約</li>
        <li>短いタイトルで要点を共有</li>
      </ul>
    </aside>
  </section>

  <section class="blog-toolbar" aria-label="ブログ概要">
    <div>
      <strong>{{ posts|length }}</strong>
      <span>件の公開投稿</span>
    </div>
    <p>新着順で表示しています。各行のコメント数から反応状況も確認できます。</p>
  </section>

  <section id="post-list" class="post-list" aria-label="イベント投稿一覧">
    {% for post in posts %}
      {% set plainContent = post.content|striptags %}
      {% set excerpt = plainContent|slice(0, 180) ~ (plainContent|length > 180 ? '…' : '') %}
      <article class="post-list-item">
        <div class="post-list-gutter" aria-hidden="true">{{ '%02d'|format(loop.index) }}</div>
        <div class="post-list-body">
          <div class="post-card-header">
            <span class="post-category">event.md</span>
            <time class="post-meta" datetime="{{ post.publishedAt|date('c') }}">{{ post.publishedAt|date('Y.m.d H:i') }}</time>
          </div>
          <h2 class="post-title">
            {% if post.id is defined and post.id %}
              <a href="{{ path('basisvr_event_show', {id: post.id}) }}">{{ post.title }}</a>
            {% else %}
              {{ post.title }}
            {% endif %}
          </h2>
          <p class="post-excerpt">{{ excerpt }}</p>
          <div class="post-footer">
            <span class="post-author">@{{ post.authorName }}</span>
            <span class="post-comment-count">{{ post.comments|length }} comments</span>
            {% if post.id is defined and post.id %}
              <a class="more-link" href="{{ path('basisvr_event_show', {id: post.id}) }}">詳細とコメントへ →</a>
            {% endif %}
          </div>
        </div>
      </article>
    {% else %}
      <div class="empty-state card">
        <h2>まだ投稿はありません</h2>
        <p>最初のイベント情報を投稿して、BasisVRコミュニティに共有しましょう。</p>
        <a class="blog-button" href="{{ path('basisvr_event_new') }}">最初の投稿を作成</a>
      </div>
    {% endfor %}
  </section>
</main>
{% endblock %}
