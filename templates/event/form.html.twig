{% extends 'base.html.twig' %}

{% block title %}イベントフォーム{% endblock %}

{% block body %}
    <h1>{{ event is defined ? 'イベント編集' : 'イベント作成' }}</h1>

    {{ form_start(form) }}
        {{ form_widget(form) }}
        <button type="submit">保存</button>
    {{ form_end(form) }}

    <p><a href="{{ path('event_index') }}">一覧に戻る</a></p>
{% endblock %}
