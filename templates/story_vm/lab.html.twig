{% extends 'base.html.twig' %}
{% block title %}SECD VM Lab{% endblock %}
{% block body %}
<style>
body{background:#0b1020;color:#e5e7eb;font-family:system-ui}
.wrap{max-width:1100px;margin:0 auto;padding:24px}
.panel{border:1px solid #334155;border-radius:10px;padding:14px;margin:12px 0;background:#111827}
table{width:100%;border-collapse:collapse}
td,th{border-bottom:1px solid #334155;padding:6px;text-align:left}
code{color:#67e8f9}
.kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:8px}
.kpi{padding:10px;border:1px solid #334155;border-radius:8px;background:#0f172a}
.log{font-size:.9rem;color:#cbd5e1}
.field{display:grid;gap:6px;margin-top:12px}
.tile{width:32px;height:32px;border-radius:8px;border:1px solid #1f2937;display:flex;align-items:center;justify-content:center;background:#0b1228;cursor:pointer;transition:.15s transform,.15s border-color,.15s box-shadow}
.tile:hover,.tile:focus-visible{transform:translateY(-1px);border-color:#93c5fd;box-shadow:0 6px 14px rgba(15,23,42,.35)}
.tile.active{border-color:#fde68a;box-shadow:0 0 0 2px rgba(250,204,21,.5)}
.tile svg{width:20px;height:20px;display:block}
.tile-soil{background:linear-gradient(160deg,#45210e,#7c4a2b)}
.tile-water{background:linear-gradient(160deg,#1e3a8a,#2563eb)}
.tile-rock{background:linear-gradient(160deg,#374151,#6b7280)}
.growth-seed .growth-ring{fill:#f59e0b}
.growth-sprout .growth-ring{fill:#22c55e}
.growth-bloom .growth-ring{fill:#f472b6}
.growth-pond .growth-ring{fill:#38bdf8}
.growth-moss .growth-ring{fill:#86efac}
.tile-icon{fill:#f8fafc;opacity:.95}
.tile-hud{margin-top:12px;padding:10px;border-radius:8px;background:#0f172a;border:1px solid #334155;min-height:64px}
.tile-hud strong{color:#93c5fd}
</style>
<main class="wrap">
<h1>SECDベース VMラボ（オンライン箱庭）</h1>
<p>UTC今日: {{ today }} / 残り命令トークン: <strong>{{ remaining_token }}</strong>（1日1命令）</p>
<p>有効Opcode: {{ allowed_opcodes|join(', ') }}</p>
<p><a href="{{ path('story_vm_admin') }}">運営管理画面（半年課題）へ</a></p>
{% if message %}<div class="panel">{{ message }}</div>{% endif %}
<div class="panel">
<h2>ワールド進行ステータス</h2>
<div class="kpis">
<div class="kpi"><strong>Day</strong><div>{{ state.world.day }}</div></div>
<div class="kpi"><strong>Chapter</strong><div>{{ state.world.chapter }}</div></div>
<div class="kpi"><strong>Objective</strong><div>{{ state.world.objective }}</div></div>
<div class="kpi"><strong>Bloom Rate</strong><div>{{ state.world.biome.bloom_rate }}%</div></div>
<div class="kpi"><strong>Weather</strong><div>{{ state.world.biome.weather }}</div></div>
<div class="kpi"><strong>Caretaker AI</strong><div>{{ state.world.npcs.caretaker_ai }}</div></div>
<div class="kpi"><strong>Global Sync</strong><div>{{ state.world.network.global_sync|default(0) }}</div></div>
</div>
</div>
<div class="panel">
<h2>命令を積む</h2>
<form method="post">
<input type="hidden" name="action" value="add_instruction">
<input name="opcode" placeholder="opcode (e.g. LDC / INFLUENCE / BROADCAST)" required>
<input name="args" placeholder="args (e.g. 10 / x / all,2 / user@example.com,1)">
<button type="submit">追加</button>
</form>
</div>
<div class="panel">
<h2>パンチコード読み込み</h2>
<form method="post">
<input type="hidden" name="action" value="load_punchcard">
<select name="punchcard_file">
{% for p in punchcards %}<option value="{{ p }}">{{ p }}</option>{% endfor %}
</select>
<button>読み込む</button>
</form>
</div>
<div class="panel">
<h2>積み上げ命令ビジュアライザ</h2>
<table><thead><tr><th>#</th><th>Opcode</th><th>Args</th><th>By</th><th>Date</th></tr></thead><tbody>
{% for row in state.program %}<tr><td>{{ loop.index }}</td><td><code>{{ row.opcode }}</code></td><td>{{ row.args }}</td><td>{{ row.by }}</td><td>{{ row.date }}</td></tr>{% else %}<tr><td colspan="5">命令なし</td></tr>{% endfor %}
</tbody></table>
<form method="post" style="margin-top:10px"><input type="hidden" name="action" value="run"><button>プログラム実行 + ターン解決</button></form>
</div>
<div class="panel">
<h2>ワールドクロニクル（共有ログ）</h2>
<ul class="log">{% for entry in state.world.chronicle|reverse %}<li>{{ entry }}</li>{% else %}<li>まだ記録がありません。</li>{% endfor %}</ul>
</div>
<div class="panel">
<h2>箱庭フィールド（タイルマップ）</h2>
<p>SVGアイコンのタイルをホバー / クリックすると、座標・地形・成長段階をインタラクティブ表示します。</p>
<div class="field" id="field-grid" style="grid-template-columns:repeat({{ state.world.field.width }},32px);">
{% for row in state.world.field.tiles %}
    {% for tile in row %}
    <button type="button" class="tile tile-{{ tile.terrain }} growth-{{ tile.growth }}" data-x="{{ tile.x }}" data-y="{{ tile.y }}" data-terrain="{{ tile.terrain }}" data-growth="{{ tile.growth }}" aria-label="{{ tile.x }},{{ tile.y }} {{ tile.terrain }} {{ tile.growth }}">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <circle class="growth-ring" cx="18" cy="6" r="4"></circle>
            {% if tile.terrain == 'soil' %}
                <path class="tile-icon" d="M6 18c2-4 4-6 6-6s4 2 6 6H6zm5-11h2v7h-2z"></path>
            {% elseif tile.terrain == 'water' %}
                <path class="tile-icon" d="M12 4c2 3 5 6 5 9a5 5 0 1 1-10 0c0-3 3-6 5-9z"></path>
            {% else %}
                <path class="tile-icon" d="M4 16l5-8 4 5 3-3 4 6H4z"></path>
            {% endif %}
        </svg>
    </button>
    {% endfor %}
{% endfor %}
</div>
<div id="tile-hud" class="tile-hud" aria-live="polite">タイルにホバーすると情報が表示されます。</div>
</div>
<div class="panel">
<h2>メモリ状況（S / E / D）</h2>
{% if state.run_result %}
<p><strong>Stack:</strong> {{ state.run_result.stack|json_encode(constant('JSON_UNESCAPED_UNICODE')) }}</p>
<p><strong>Environment:</strong> {{ state.run_result.env|json_encode(constant('JSON_UNESCAPED_UNICODE')) }}</p>
<p><strong>Dump:</strong> {{ state.run_result.dump|json_encode(constant('JSON_UNESCAPED_UNICODE')) }}</p>
<h3>実行トレース</h3>
<table><thead><tr><th>PC</th><th>Opcode</th><th>Stack</th><th>Env</th><th>Dump</th></tr></thead><tbody>
{% for t in state.run_result.trace %}<tr><td>{{ t.pc }}</td><td>{{ t.opcode }}</td><td>{{ t.stack|json_encode }}</td><td>{{ t.env|json_encode }}</td><td>{{ t.dump|json_encode }}</td></tr>{% endfor %}
</tbody></table>
{% else %}<p>まだ実行していません。</p>{% endif %}
</div>
</main>
<script>
(() => {
  const hud = document.getElementById('tile-hud');
  const tiles = document.querySelectorAll('#field-grid .tile');
  const render = (el) => {
    hud.innerHTML = `<strong>Tile (${el.dataset.x}, ${el.dataset.y})</strong><br>Terrain: ${el.dataset.terrain}<br>Growth: ${el.dataset.growth}`;
  };

  tiles.forEach((tile) => {
    tile.addEventListener('mouseenter', () => render(tile));
    tile.addEventListener('focus', () => render(tile));
    tile.addEventListener('click', () => {
      document.querySelectorAll('#field-grid .tile.active').forEach((active) => active.classList.remove('active'));
      tile.classList.add('active');
      render(tile);
    });
  });
})();
</script>
{% endblock %}
