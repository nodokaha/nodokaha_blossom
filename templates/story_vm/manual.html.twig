{% extends 'base.html.twig' %}

{% block title %}VM仕様マニュアル{% endblock %}

{% block body %}
    <style>
        body {
            margin: 0;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #020617;
            color: #e2e8f0;
            line-height: 1.7;
        }

        .wrap {
            max-width: 980px;
            margin: 0 auto;
            padding: 42px 20px 72px;
        }

        .panel {
            border: 1px solid #334155;
            border-radius: 12px;
            background: #0f172a;
            padding: 20px;
            margin-top: 16px;
        }

        .title { margin: 0; }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th, td {
            text-align: left;
            vertical-align: top;
            padding: 10px;
            border-bottom: 1px solid #334155;
        }

        .back {
            color: #67e8f9;
            text-decoration: none;
            font-weight: 600;
        }
    </style>

    <main class="wrap">
        <a class="back" href="{{ path('story_vm_home') }}">← トップに戻る</a>
        <h1 class="title">仮想言語仕様書（運用マニュアル）</h1>
        <p>運営・プレイヤー向けに、現在のVM設定と命令仕様を一覧化した画面です。</p>

        <section class="panel" aria-label="VM設定">
            <h2>VM設定</h2>
            <ul>
                {% for key, value in vm_settings %}
                    <li><strong>{{ key }}</strong>: {{ value }}</li>
                {% endfor %}
            </ul>
        </section>

        <section class="panel" aria-label="命令セット">
            <h2>仮想言語命令セット</h2>
            <table>
                <thead>
                    <tr>
                        <th>Opcode</th>
                        <th>引数</th>
                        <th>挙動</th>
                    </tr>
                </thead>
                <tbody>
                    {% for instruction in instruction_set %}
                        <tr>
                            <td><code>{{ instruction.opcode }}</code></td>
                            <td>{{ instruction.args }}</td>
                            <td>{{ instruction.effect }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </main>
{% endblock %}
