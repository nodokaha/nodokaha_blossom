{% extends 'base.html.twig' %}

{% block title %}ログイン{% endblock %}

{% block body %}
<main style="max-width: 560px; margin: 2.5rem auto; padding: 0 1rem;">
    <section style="background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.5rem; box-shadow: 0 8px 24px rgba(15,23,42,.06);">
        <h1 style="margin-top:0;">ログイン</h1>
        <p style="color:#334155; margin-top:-0.25rem;">ログイン後はレビュー記事の投稿とコメント確認へ移動できます。</p>

        {% for message in app.flashes('success') %}
            <p style="color: #166534; background: #f0fdf4; border: 1px solid #bbf7d0; padding: .7rem; border-radius: 8px;">
                {{ message }}
            </p>
        {% endfor %}

        {% if error %}
            <p style="color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; padding: .7rem; border-radius: 8px;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </p>
        {% endif %}

        <form method="post">
            <label for="username">メールアドレス</label>
            <input id="username" name="_username" type="email" value="{{ last_username }}" required style="width:100%; margin:.35rem 0 1rem; padding:.65rem; border:1px solid #cbd5e1; border-radius:8px; box-sizing: border-box;">

            <label for="password">パスワード</label>
            <input id="password" name="_password" type="password" required style="width:100%; margin:.35rem 0 1rem; padding:.65rem; border:1px solid #cbd5e1; border-radius:8px; box-sizing: border-box;">

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" style="border:none; border-radius:10px; padding:.7rem 1rem; color:#fff; background:linear-gradient(90deg,#2563eb,#7c3aed); font-weight:700; cursor:pointer;">ログインする</button>
        </form>
    </section>
</main>
{% endblock %}
