{% extends 'base.html.twig' %}

{% block title %}{{ garden.name }} の命令一覧{% endblock %}

{% block body %}
    <main style="max-width: 900px; margin: 2rem auto; padding: 1rem;">
        <h1>{{ garden.name }} の命令一覧</h1>
        <p>この箱庭に登録された命令の履歴を確認できます。</p>

        {% if commands is empty %}
            <p>まだ命令は登録されていません。</p>
        {% else %}
            <table style="width:100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="text-align:left; border-bottom:1px solid #ddd; padding: .8rem;">日付</th>
                        <th style="text-align:left; border-bottom:1px solid #ddd; padding: .8rem;">命令</th>
                        <th style="text-align:left; border-bottom:1px solid #ddd; padding: .8rem;">状態</th>
                        <th style="text-align:left; border-bottom:1px solid #ddd; padding: .8rem;">実行結果</th>
                    </tr>
                </thead>
                <tbody>
                    {% for command in commands %}
                        <tr>
                            <td style="padding: .8rem; border-bottom:1px solid #222;">{{ command.insertedDate|date('Y-m-d') }}</td>
                            <td style="padding: .8rem; border-bottom:1px solid #222;">{{ command.command.opcode|default('UNKNOWN') }} {{ command.command.args|default('') }}</td>
                            <td style="padding: .8rem; border-bottom:1px solid #222;">{{ command.status }}</td>
                            <td style="padding: .8rem; border-bottom:1px solid #222;">{{ command.executionResult is not empty ? command.executionResult|json_encode : '–' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}

        <p><a href="{{ path('app_garden_dashboard', { userId: garden.owner.id }) }}">箱庭へ戻る</a></p>
    </main>
{% endblock %}
