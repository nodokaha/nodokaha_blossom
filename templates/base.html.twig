<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>■</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="retro-header">
            <nav class="retro-nav">
                <a href="{{ path('app_home') }}" class="brand-link">NODOKAHA BLOSSOM</a>
                <a href="{{ path('app_home') }}">トップ</a>
                <a href="{{ path('app_garden_list') }}">箱庭一覧</a>

                {% if app.user %}
                    <a href="{{ path('app_garden_dashboard', { userId: app.user.id }) }}">マイ箱庭</a>
                    <span class="retro-user">{{ app.user.userIdentifier }}</span>
                    <form method="post" action="{{ path('app_logout') }}" class="retro-logout-form">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                        <button type="submit">ログアウト</button>
                    </form>
                {% else %}
                    <a href="{{ path('app_register') }}">ユーザー登録</a>
                    <a href="{{ path('app_login') }}">ログイン</a>
                {% endif %}
            </nav>
        </header>

        {% block body %}{% endblock %}
    </body>
</html>
