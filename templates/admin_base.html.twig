<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Admin{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body style="margin:0;font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#0b1220;color:#e2e8f0;">
        <header style="position: sticky; top: 0; z-index: 50; background: rgba(2, 6, 23, 0.95); border-bottom: 1px solid #334155;">
            <nav style="max-width: 1080px; margin: 0 auto; padding: 0.75rem 1rem; display: flex; align-items: center; gap: 0.75rem;">
                <a href="{{ path('story_vm_admin') }}" style="font-weight:700;color:#e2e8f0;text-decoration:none;">🛠 管理コンソール</a>
                <a href="{{ path('story_vm_home') }}" style="color:#93c5fd;text-decoration:none;">ユーザー画面へ戻る</a>
                {% if app.user %}
                    <span style="margin-left:auto;">{{ app.user.userIdentifier }}</span>
                    <form method="post" action="{{ path('app_logout') }}" style="margin:0;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                        <button type="submit" style="border:1px solid #64748b; background:transparent; color:#e2e8f0; border-radius:999px; padding:.3rem .75rem;">ログアウト</button>
                    </form>
                {% endif %}
            </nav>
        </header>

        {% block body %}{% endblock %}
    </body>
</html>
