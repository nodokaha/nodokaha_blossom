{% extends 'base.html.twig' %}

{% block title %}みんなの箱庭{% endblock %}

{% block body %}
    <main style="max-width: 900px; margin: 2rem auto; padding: 1rem;">
        <h1>みんなの箱庭一覧</h1>
        <p>他ユーザーが作成した箱庭を一覧で観察できます。</p>
        <p style='font-size:0.9rem;color:#666;'>グローバル同期: {{ network.global_sync|default(0) }}</p>

        {% if rankedGardens is not empty %}
            <section style="margin: 1rem 0; padding: 1rem; background: #111827; border: 1px solid #334155; border-radius: 12px;">
                <h2 style="margin-top: 0;">スコアランキング</h2>
                <ol style="margin:0;padding-left:1.2rem;color:#e5e7eb;">
                    {% for entry in rankedGardens|slice(0, 3) %}
                        <li style="margin-bottom:.5rem;">
                            <strong>{{ entry.garden.name }}</strong> — スコア {{ entry.score }} / {{ entry.status.prosperity }}
                            <div style="font-size:0.9rem;color:#94a3b8;">オーナー: {{ entry.garden.owner.email }}</div>
                        </li>
                    {% endfor %}
                </ol>
            </section>
        {% endif %}

        {% if gardens is empty %}
            <p>まだ箱庭は作成されていません。</p>
        {% else %}
            <ul style="display: grid; gap: 1rem; list-style: none; padding: 0;">
                {% for garden in gardens %}
                    <li style="border: 1px solid #ddd; border-radius: 8px; padding: 1rem;">
                        <h2 style="margin-top: 0;">{{ garden.name }}</h2>
                        <p>{{ garden.description }}</p>
                        {% set ownerKey = garden.owner.email|lower %}
                        {% set targeted = network.garden_influence[ownerKey]|default(0) %}
                        {% set shared = network.garden_influence['all']|default(0) %}
                        <p style="font-size: 0.9rem; color: #666; margin-bottom: 0;">オーナー: {{ garden.owner.email }}</p>
                        {% set status = statuses[garden.id]|default(null) %}
                        <p style="font-size: 0.9rem; color: #4b5563; margin-top: 0.3rem;">オンライン干渉: {{ targeted + shared }} (target {{ targeted }}, all {{ shared }})</p>
                        {% if status %}
                            <p style="font-size: 0.9rem; color: #374151; margin: 0.35rem 0 0;">人口 {{ status.population }}人 / 食料 {{ status.food }}t / 資金 {{ status.treasury }}億円</p>
                            <p style="font-size: 0.9rem; color: #374151; margin: 0.2rem 0 0;">発展段階: {{ status.prosperity }} ・ 状態: {{ status.danger }}</p>
                        {% endif %}
                        {% if garden.owner is defined and garden.owner.id is defined and garden.owner.id %}
                            <p style="margin-top:.75rem;"><a href="{{ path('app_garden_dashboard', { userId: garden.owner.id }) }}">この箱庭を観察する</a></p>
                        {% else %}
                            <p style="margin-top:.75rem;color:#94a3b8;">観察リンクなし</p>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </main>
{% endblock %}
